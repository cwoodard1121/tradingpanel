# Supabase — copy this file to `.env.local` and fill in your project's values.
# Found in Supabase: Project Settings -> API.
#
# If you leave these blank, the app automatically falls back to storing
# everything in your browser's localStorage so you can use it right away.
# Add these (locally and in Vercel) to sync across your phone + desktop.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL — server-only. Bypasses Row Level Security; NEVER expose to the browser.
# The app does NOT use this (it talks to Supabase with the anon key only). It's here
# purely for future server-side / admin scripts. Note: there is no NEXT_PUBLIC_ prefix,
# so Next.js will never ship it to the client bundle.
SUPABASE_SERVICE_ROLE=
